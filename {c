services:
  ai-career-os:
    build: .
    image: ai-career-os:latest
    container_name: ai-career-os
    stdin_open: true
    tty: true
    depends_on:
      - postgres

  postgres:
    image: postgres:17
    container_name: postgres-db
    environment:
      POSTGRES_USER: stefano
      POSTGRES_PASSWORD: password123
      POSTGRES_DB: ai_career_os

